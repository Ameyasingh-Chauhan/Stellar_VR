# Environment variables for STELLAR VR180 Backend

# Server configuration
PORT=8000
HOST=0.0.0.0

# Model configuration
MODEL_CHOICE=DPT_Hybrid
FORCE_DEVICE=cpu

# Processing defaults
TARGET_RESOLUTION=1440
DISPARITY=14.0

# Quality settings (CRF values for different quality levels)
CRF_LOW=26
CRF_MEDIUM=21
CRF_HIGH=18

# Hugging Face Token (if using private models)
HF_TOKEN=

# Temporary directory
TMP_DIR=/tmp/stellar_vr_backend